<Window x:Class="DiscordTokenChecker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Discord Token Checker" 
        Height="700" Width="1150" MinHeight="550" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgDarkBrush}"
        FontFamily="Segoe UI"
        Foreground="{StaticResource TextPrimaryBrush}">

    <Window.Resources>
        <!-- DataGrid Style -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{StaticResource BgMediumBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowBackground" Value="{StaticResource BgMediumBrush}"/>
            <Setter Property="AlternatingRowBackground" Value="{StaticResource BgDarkBrush}"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource BgDarkestBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderBrush" Value="{StaticResource BgLightBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background">
                        <Setter.Value>
                            <SolidColorBrush Color="#5865F2" Opacity="0.3"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background">
                        <Setter.Value>
                            <SolidColorBrush Color="{StaticResource BgLight}" Opacity="0.7"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Tab Button Style -->
        <Style x:Key="TabButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background">
                                    <Setter.Value>
                                        <SolidColorBrush Color="{StaticResource BgLight}" Opacity="0.5"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TabButtonActive" TargetType="Button" BasedOn="{StaticResource TabButton}">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource BlurpleBrush}"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="48"/>
        </Grid.RowDefinitions>

        <!-- ═══ HEADER BAR ═══ -->
        <Border Grid.Row="0" Background="{StaticResource BgDarkestBrush}" Padding="16,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="32" Height="32" Margin="0,0,12,0">
                        <Ellipse.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#5865F2" Offset="0"/>
                                <GradientStop Color="#7B68EE" Offset="1"/>
                            </LinearGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>
                    <TextBlock Text="⚡" FontSize="18" Margin="-38,0,18,0" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    <TextBlock Text="Discord Token Checker" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" Foreground="White"/>
                    <Border Background="{StaticResource BlurpleBrush}" CornerRadius="3" Padding="6,2" Margin="10,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="v1.2.0" FontSize="10" Foreground="White"/>
                    </Border>
                </StackPanel>

                <TextBlock Grid.Column="2" Text="by pierdas" FontSize="12" 
                           Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ═══ MAIN CONTENT ═══ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ─── LEFT PANEL ─── -->
            <Border Grid.Column="0" Background="{StaticResource BgDarkestBrush}" Margin="0,0,1,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="16,16,16,16">
                        
                        <!-- LOAD TOKENS -->
                        <TextBlock Text="TOKEN LIST" FontSize="11" FontWeight="Bold" 
                                   Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,8"/>
                        
                        <Button x:Name="btnLoadTokens" Content="📂  Load Tokens" 
                                Style="{StaticResource DiscordButton}" 
                                HorizontalAlignment="Stretch" Click="BtnLoadTokens_Click"/>
                        
                        <Border Background="{StaticResource BgDarkBrush}" CornerRadius="4" 
                                Padding="10,8" Margin="0,8,0,0">
                            <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="11">
                                <Run Text="Loaded: "/>
                                <Run x:Name="txtTokenCount" Text="0" Foreground="{StaticResource GreenBrush}" FontWeight="Bold"/>
                                <Run Text=" tokens"/>
                            </TextBlock>
                        </Border>

                        <!-- PROXY -->
                        <TextBlock Text="PROXIES" FontSize="11" FontWeight="Bold" 
                                   Foreground="{StaticResource TextMutedBrush}" Margin="0,20,0,8"/>

                        <Button x:Name="btnLoadProxies" Content="🌐  Load Proxies" 
                                Style="{StaticResource SecondaryButton}" 
                                HorizontalAlignment="Stretch" Click="BtnLoadProxies_Click"/>

                        <Border Background="{StaticResource BgDarkBrush}" CornerRadius="4" 
                                Padding="10,8" Margin="0,8,0,0">
                            <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="11">
                                <Run Text="Proxies: "/>
                                <Run x:Name="txtProxyCount" Text="0" Foreground="{StaticResource BlurpleBrush}" FontWeight="Bold"/>
                                <Run Text=" | Mode: "/>
                                <Run x:Name="txtProxyMode" Text="Proxyless" Foreground="{StaticResource YellowBrush}" FontWeight="Bold"/>
                            </TextBlock>
                        </Border>

                        <TextBlock Text="IP:PORT or IP:PORT:USER:PASS" FontSize="9" 
                                   Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0"
                                   FontStyle="Italic"/>

                        <!-- THREADS -->
                        <TextBlock Text="THREADS" FontSize="11" FontWeight="Bold" 
                                   Foreground="{StaticResource TextMutedBrush}" Margin="0,20,0,8"/>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>
                            <Slider x:Name="sliderThreads" Minimum="1" Maximum="100" Value="50" 
                                    VerticalAlignment="Center" IsSnapToTickEnabled="True" TickFrequency="1"/>
                            <Border Grid.Column="1" Background="{StaticResource BgDarkBrush}" CornerRadius="4" Padding="4,2" Margin="6,0,0,0">
                                <TextBlock x:Name="txtThreads" Text="50" FontSize="12" FontWeight="Bold"
                                           Foreground="{StaticResource BlurpleBrush}" HorizontalAlignment="Center"/>
                            </Border>
                        </Grid>

                        <!-- CONTROLS -->
                        <TextBlock Text="CONTROLS" FontSize="11" FontWeight="Bold" 
                                   Foreground="{StaticResource TextMutedBrush}" Margin="0,24,0,8"/>

                        <Button x:Name="btnStart" Content="▶  Start Checking" 
                                Style="{StaticResource DiscordButton}" 
                                HorizontalAlignment="Stretch" Click="BtnStart_Click"
                                Margin="0,0,0,6"/>

                        <Button x:Name="btnStop" Content="⏹  Stop" 
                                Style="{StaticResource DangerButton}" 
                                HorizontalAlignment="Stretch" Click="BtnStop_Click"
                                IsEnabled="False" Margin="0,0,0,6"/>

                        <!-- EXPORT -->
                        <TextBlock Text="EXPORT" FontSize="11" FontWeight="Bold" 
                                   Foreground="{StaticResource TextMutedBrush}" Margin="0,24,0,8"/>

                        <Button x:Name="btnExportHits" Content="💾  Export Hits" 
                                Style="{StaticResource SecondaryButton}" 
                                HorizontalAlignment="Stretch" Click="BtnExportHits_Click"
                                Margin="0,0,0,6"/>

                        <Button x:Name="btnExportAll" Content="📋  Export All" 
                                Style="{StaticResource SecondaryButton}" 
                                HorizontalAlignment="Stretch" Click="BtnExportAll_Click"/>

                        <!-- NOTIFICATIONS -->
                        <TextBlock Text="NOTIFICATIONS" FontSize="11" FontWeight="Bold" 
                                   Foreground="{StaticResource TextMutedBrush}" Margin="0,24,0,8"/>

                        <Border Background="{StaticResource BgDarkBrush}" CornerRadius="6" Padding="10">
                            <StackPanel>
                                <!-- Discord Webhook -->
                                <TextBlock Text="Discord Webhook" FontSize="10" 
                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                <TextBox x:Name="txtWebhook" Height="28" FontSize="11"
                                         Background="#1E1F22" Foreground="#B5BAC1" BorderBrush="#404249"
                                         BorderThickness="1" Padding="6,4"
                                         ToolTip="Paste Discord Webhook URL"/>

                                <Border Height="1" Background="{StaticResource BgLighterBrush}" Margin="0,10,0,10"/>

                                <!-- Telegram -->
                                <TextBlock Text="Telegram Bot Token" FontSize="10" 
                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                <TextBox x:Name="txtTgToken" Height="28" FontSize="11"
                                         Background="#1E1F22" Foreground="#B5BAC1" BorderBrush="#404249"
                                         BorderThickness="1" Padding="6,4"
                                         ToolTip="Bot token from @BotFather"/>

                                <TextBlock Text="Telegram Chat ID" FontSize="10" 
                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,6,0,4"/>
                                <TextBox x:Name="txtTgChatId" Height="28" FontSize="11"
                                         Background="#1E1F22" Foreground="#B5BAC1" BorderBrush="#404249"
                                         BorderThickness="1" Padding="6,4"
                                         ToolTip="Chat ID or @channel"/>
                            </StackPanel>
                        </Border>

                        <!-- LIVE STATS -->
                        <TextBlock Text="STATISTICS" FontSize="11" FontWeight="Bold" 
                                   Foreground="{StaticResource TextMutedBrush}" Margin="0,24,0,8"/>

                        <Border Background="{StaticResource BgDarkBrush}" CornerRadius="6" Padding="12">
                            <StackPanel>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Valid" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                    <TextBlock x:Name="txtValid" Grid.Column="1" Text="0" 
                                               Foreground="{StaticResource GreenBrush}" FontSize="14" FontWeight="Bold"/>
                                </Grid>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Invalid" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                    <TextBlock x:Name="txtInvalid" Grid.Column="1" Text="0" 
                                               Foreground="{StaticResource RedBrush}" FontSize="14" FontWeight="Bold"/>
                                </Grid>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Errors" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                    <TextBlock x:Name="txtErrors" Grid.Column="1" Text="0" 
                                               Foreground="{StaticResource YellowBrush}" FontSize="14" FontWeight="Bold"/>
                                </Grid>
                                <Border Height="1" Background="{StaticResource BgLightBrush}" Margin="0,4,0,8"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="CPM" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                    <TextBlock x:Name="txtCPM" Grid.Column="1" Text="0" 
                                               Foreground="{StaticResource BlurpleBrush}" FontSize="14" FontWeight="Bold"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- ─── RIGHT PANEL: TABS + DATA GRID ─── -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- TAB BAR -->
                <Border Grid.Row="0" Background="{StaticResource BgDarkestBrush}">
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="tabAll" Content="📋 All" 
                                Style="{StaticResource TabButtonActive}" Click="TabAll_Click"/>
                        <Button x:Name="tabValid" Content="✅ Valid" 
                                Style="{StaticResource TabButton}" Click="TabValid_Click"/>
                        <Button x:Name="tabInvalid" Content="❌ Invalid" 
                                Style="{StaticResource TabButton}" Click="TabInvalid_Click"/>
                        <Button x:Name="tabErrors" Content="⚠ Errors" 
                                Style="{StaticResource TabButton}" Click="TabErrors_Click"/>
                    </StackPanel>
                </Border>

                <!-- DATA GRID -->
                <Border Grid.Row="1">
                    <DataGrid x:Name="dgResults">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="70"/>
                            <DataGridTextColumn Header="Username" Binding="{Binding Username}" Width="110"/>
                            <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="160"/>
                            <DataGridTextColumn Header="Phone" Binding="{Binding Phone}" Width="110"/>
                            <DataGridTextColumn Header="Nitro" Binding="{Binding NitroType}" Width="80"/>
                            <DataGridTextColumn Header="Nitro Since" Binding="{Binding NitroSince}" Width="90"/>
                            <DataGridTextColumn Header="2FA" Binding="{Binding TwoFA}" Width="50"/>
                            <DataGridTextColumn Header="Locale" Binding="{Binding Locale}" Width="55"/>
                            <DataGridTextColumn Header="Verified" Binding="{Binding Verified}" Width="60"/>
                            <DataGridTextColumn Header="Connected" Binding="{Binding ConnectedAccounts}" Width="120"/>
                            <DataGridTextColumn Header="Payment" Binding="{Binding PaymentInfo}" Width="180"/>
                            <DataGridTextColumn Header="Token" Binding="{Binding TokenShort}" Width="160"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </Grid>
        </Grid>

        <!-- ═══ BOTTOM STATUS BAR ═══ -->
        <Border Grid.Row="2" Background="{StaticResource BgDarkestBrush}" Padding="16,0">
            <Grid VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Margin="0,0,20,0">
                    <ProgressBar x:Name="progressBar" Height="6" Minimum="0" Maximum="100" Value="0"
                                 Background="{StaticResource BgLightBrush}" Foreground="{StaticResource BlurpleBrush}"
                                 BorderThickness="0"/>
                </Grid>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock x:Name="txtProgress" Text="0 / 0" FontSize="12" 
                               Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
