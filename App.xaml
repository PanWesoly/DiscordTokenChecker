<Application x:Class="DiscordTokenChecker.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <!-- Discord Dark Theme Colors -->
            <Color x:Key="BgDarkest">#1E1F22</Color>
            <Color x:Key="BgDark">#2B2D31</Color>
            <Color x:Key="BgMedium">#313338</Color>
            <Color x:Key="BgLight">#383A40</Color>
            <Color x:Key="BgLighter">#404249</Color>
            <Color x:Key="Blurple">#5865F2</Color>
            <Color x:Key="BlurpleHover">#4752C4</Color>
            <Color x:Key="Green">#57F287</Color>
            <Color x:Key="Red">#ED4245</Color>
            <Color x:Key="Yellow">#FEE75C</Color>
            <Color x:Key="TextPrimary">#F2F3F5</Color>
            <Color x:Key="TextSecondary">#B5BAC1</Color>
            <Color x:Key="TextMuted">#6D6F78</Color>

            <SolidColorBrush x:Key="BgDarkestBrush" Color="{StaticResource BgDarkest}"/>
            <SolidColorBrush x:Key="BgDarkBrush" Color="{StaticResource BgDark}"/>
            <SolidColorBrush x:Key="BgMediumBrush" Color="{StaticResource BgMedium}"/>
            <SolidColorBrush x:Key="BgLightBrush" Color="{StaticResource BgLight}"/>
            <SolidColorBrush x:Key="BgLighterBrush" Color="{StaticResource BgLighter}"/>
            <SolidColorBrush x:Key="BlurpleBrush" Color="{StaticResource Blurple}"/>
            <SolidColorBrush x:Key="BlurpleHoverBrush" Color="{StaticResource BlurpleHover}"/>
            <SolidColorBrush x:Key="GreenBrush" Color="{StaticResource Green}"/>
            <SolidColorBrush x:Key="RedBrush" Color="{StaticResource Red}"/>
            <SolidColorBrush x:Key="YellowBrush" Color="{StaticResource Yellow}"/>
            <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}"/>
            <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}"/>
            <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMuted}"/>

            <!-- Button Style -->
            <Style x:Key="DiscordButton" TargetType="Button">
                <Setter Property="Background" Value="{StaticResource BlurpleBrush}"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontFamily" Value="Segoe UI"/>
                <Setter Property="Padding" Value="16,8"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="{TemplateBinding Background}" 
                                    CornerRadius="4" Padding="{TemplateBinding Padding}"
                                    SnapsToDevicePixels="True">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="{StaticResource BlurpleHoverBrush}"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="bd" Property="Opacity" Value="0.5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource DiscordButton}">
                <Setter Property="Background" Value="{StaticResource RedBrush}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="{TemplateBinding Background}" 
                                    CornerRadius="4" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background">
                                        <Setter.Value>
                                            <SolidColorBrush Color="#C03537"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="bd" Property="Opacity" Value="0.5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource DiscordButton}">
                <Setter Property="Background" Value="{StaticResource BgLighterBrush}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="{TemplateBinding Background}" 
                                    CornerRadius="4" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background">
                                        <Setter.Value>
                                            <SolidColorBrush Color="#4E505A"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="bd" Property="Opacity" Value="0.5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ══ Custom Slider Thumb ══ -->
            <Style x:Key="SliderThumbStyle" TargetType="Thumb">
                <Setter Property="Width" Value="18"/>
                <Setter Property="Height" Value="18"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Thumb">
                            <Grid>
                                <!-- Glow behind thumb -->
                                <Ellipse x:Name="glow" Width="24" Height="24" Opacity="0">
                                    <Ellipse.Fill>
                                        <RadialGradientBrush>
                                            <GradientStop Color="#5865F2" Offset="0.2"/>
                                            <GradientStop Color="Transparent" Offset="1"/>
                                        </RadialGradientBrush>
                                    </Ellipse.Fill>
                                </Ellipse>
                                <!-- Main circle -->
                                <Ellipse x:Name="circle" Width="16" Height="16" StrokeThickness="0">
                                    <Ellipse.Fill>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#6C78FF" Offset="0"/>
                                            <GradientStop Color="#5865F2" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Ellipse.Fill>
                                    <Ellipse.Effect>
                                        <DropShadowEffect Color="#5865F2" BlurRadius="6" ShadowDepth="0" Opacity="0.5"/>
                                    </Ellipse.Effect>
                                </Ellipse>
                                <!-- Inner dot -->
                                <Ellipse x:Name="dot" Width="6" Height="6" Fill="White" Opacity="0.9"/>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="circle" Property="Width" Value="18"/>
                                    <Setter TargetName="circle" Property="Height" Value="18"/>
                                    <Setter TargetName="glow" Property="Opacity" Value="0.4"/>
                                </Trigger>
                                <Trigger Property="IsDragging" Value="True">
                                    <Setter TargetName="circle" Property="Width" Value="20"/>
                                    <Setter TargetName="circle" Property="Height" Value="20"/>
                                    <Setter TargetName="glow" Property="Opacity" Value="0.6"/>
                                    <Setter TargetName="dot" Property="Width" Value="7"/>
                                    <Setter TargetName="dot" Property="Height" Value="7"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ══ Custom Slider ══ -->
            <Style TargetType="Slider">
                <Setter Property="Height" Value="24"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Slider">
                            <Grid VerticalAlignment="Center">
                                <!-- Background track -->
                                <Border x:Name="TrackBg" Height="6" CornerRadius="3"
                                        Background="{StaticResource BgLighterBrush}" VerticalAlignment="Center"/>
                                <!-- Filled track (blurple) -->
                                <Canvas ClipToBounds="True" VerticalAlignment="Center" Height="6">
                                    <Border x:Name="TrackFill" Height="6" CornerRadius="3"
                                            HorizontalAlignment="Left" VerticalAlignment="Center">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#5865F2" Offset="0"/>
                                                <GradientStop Color="#7B68EE" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>
                                </Canvas>
                                <!-- WPF Track for thumb positioning -->
                                <Track x:Name="PART_Track" VerticalAlignment="Center">
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton Command="Slider.DecreaseLarge" Opacity="0" Height="6"/>
                                    </Track.DecreaseRepeatButton>
                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton Command="Slider.IncreaseLarge" Opacity="0" Height="6"/>
                                    </Track.IncreaseRepeatButton>
                                    <Track.Thumb>
                                        <Thumb Style="{StaticResource SliderThumbStyle}"/>
                                    </Track.Thumb>
                                </Track>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ══ Custom ScrollBar Thumb ══ -->
            <Style x:Key="ScrollBarThumb" TargetType="Thumb">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Thumb">
                            <Border x:Name="bg" CornerRadius="4" Background="#3B3D44" Margin="2"/>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bg" Property="Background" Value="#4E505A"/>
                                </Trigger>
                                <Trigger Property="IsDragging" Value="True">
                                    <Setter TargetName="bg" Property="Background" Value="#5865F2"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ══ Custom Vertical ScrollBar ══ -->
            <Style TargetType="ScrollBar">
                <Setter Property="Width" Value="10"/>
                <Setter Property="MinWidth" Value="10"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ScrollBar">
                            <Grid>
                                <Track x:Name="PART_Track" IsDirectionReversed="True">
                                    <Track.Thumb>
                                        <Thumb Style="{StaticResource ScrollBarThumb}"/>
                                    </Track.Thumb>
                                </Track>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="Orientation" Value="Horizontal">
                        <Setter Property="Height" Value="10"/>
                        <Setter Property="MinHeight" Value="10"/>
                        <Setter Property="Width" Value="Auto"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ScrollBar">
                                    <Grid>
                                        <Track x:Name="PART_Track" IsDirectionReversed="False">
                                            <Track.Thumb>
                                                <Thumb Style="{StaticResource ScrollBarThumb}"/>
                                            </Track.Thumb>
                                        </Track>
                                    </Grid>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- ScrollViewer -->
            <Style TargetType="ScrollViewer">
                <Setter Property="Background" Value="Transparent"/>
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
